def get_user(user_id):
    if user_id not in users:
        users[user_id] = {
            "free_questions": 5,
            "plan": "free",  # free / monthly / vip / premium
            "questions_left": 5
        }
    return users[user_id]

def can_ask(user_id):
    u = get_user(user_id)
    if u["plan"] == "free":
        return u["free_questions"] > 0
    elif u["plan"] == "monthly":
        return u["questions_left"] > 0
    elif u["plan"] in ["vip", "premium"]:
        return True
    return False

def can_get_code(user_id):
    u = get_user(user_id)
    return u["plan"] in ["vip", "premium"]

