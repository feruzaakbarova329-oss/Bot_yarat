# Savol berish
@dp.message(F.text & ~F.text.startswith("/"))
async def handle_question(message: types.Message):
    user_id = message.from_user.id
    u = get_user(user_id)

    if not can_ask(user_id):
        kb = InlineKeyboardMarkup(inline_keyboard=[
            [InlineKeyboardButton(text="💳 Obuna sotib olish", callback_data="payment")]
        ])
        await message.answer("❌ Savollar tugadi! Obuna sotib oling.", reply_markup=kb)
        return

    await message.answer("⏳ Javob tayyorlanmoqda...")

    # Claude API
    system_prompt = "Sen Telegram bot yaratishga yordam beruvchi ekspertsan. Foydalanuvchiga bot qanday yasalishini tushuntir."
    
    give_code = can_get_code(user_id)
    if not give_code:
        system_prompt += " MUHIM: Hech qanday kod yozma! Faqat tushuntir va to'lov kerakligini ayt."

    response = client.messages.create(
        model="claude-opus-4-5",
        max_tokens=1000,
        system=system_prompt,
        messages=[{"role": "user", "content": message.text}]
    )

    answer = response.content[0].text

    # Savolni kamayt
    if u["plan"] == "free":
        u["free_questions"] -= 1
    elif u["plan"] == "monthly":
        u["questions_left"] -= 1

    qolgan = u["free_questions"] if u["plan"] == "free" else u["questions_left"] if u["plan"] == "monthly" else "♾️"
    
    await message.answer(f"{answer}\n\n📊 Qolgan savollar: {qolgan}")

# Admin: obunani faollashtirish
# /activate 123456789 monthly
@dp.message(Command("activate"))
async def activate(message: types.Message):
    if message.from_user.id != ADMIN_ID:
        return
    
    parts = message.text.split()
    if len(parts) != 3:
        await message.answer("Format: /activate USER_ID plan\nPlanlar: monthly, vip, premium")
        return
    
    target_id = int(parts[1])
    plan = parts[2]
    
    u = get_user(target_id)
    u["plan"] = plan
    if plan == "monthly":
        u["questions_left"] = 50
    
    await message.answer(f"✅ Foydalanuvchi {target_id} uchun {plan} tarif faollashtirildi!")
    await bot.send_message(target_id, f"🎉 Sizning obunangiz faollashtirildi: {plan.upper()}")

